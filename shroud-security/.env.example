# 1Claw Shroud Security Example
# Copy this file to .env and fill in your credentials

# Required for setup only (creates agent with security config)
ONECLAW_API_KEY=

# Required for tests (auto-populated by setup)
ONECLAW_AGENT_ID=
ONECLAW_AGENT_API_KEY=

# Optional: custom endpoints
ONECLAW_SHROUD_URL=https://shroud.1claw.xyz
ONECLAW_API_URL=https://api.1claw.xyz

# For LLM proxy tests
OPENAI_API_KEY=
